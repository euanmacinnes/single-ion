# photon-base-micromamba3.13 — Photon kernel image with micromamba + Python 3.13 + CUDA 12.8
#
# Base: mambaorg/micromamba:2.3.0-cuda12.8.1-ubuntu24.04
# Python: 3.13 via micromamba
#
# Build from the monorepo root (photon-base must be built first):
#   docker build \
#     --build-arg BASE_IMAGE=photon-base:latest \
#     -f neutrino/files/base/Dockerfile.photon-base-micromamba3.13 \
#     -t photon-base-micromamba3.13:latest .

ARG BASE_IMAGE=photon-base:latest
FROM ${BASE_IMAGE} AS photon

FROM mambaorg/micromamba:2.3.0-cuda12.8.1-ubuntu24.04

USER root

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       ca-certificates \
       libssl3 \
    && rm -rf /var/lib/apt/lists/*

# Install Python 3.13 into the base environment
RUN micromamba install -y -n base python=3.13 \
    && micromamba clean -afy

COPY --from=photon /usr/local/bin/kernel-manager /usr/local/bin/kernel-manager

EXPOSE 8090

ENTRYPOINT ["/usr/local/bin/kernel-manager"]
CMD []
