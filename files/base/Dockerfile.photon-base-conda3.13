# photon-base-conda3.13 — Photon kernel image with Miniconda + Python 3.13 + CUDA 12.8
#
# CUDA base: nvidia/cuda:12.8.1-base-ubuntu24.04
# Conda distribution: Miniconda (conda package manager)
# Python: 3.13 via conda
#
# Build from the monorepo root (photon-base must be built first):
#   docker build \
#     --build-arg BASE_IMAGE=photon-base:latest \
#     -f neutrino/files/base/Dockerfile.photon-base-conda3.13 \
#     -t photon-base-conda3.13:latest .

ARG BASE_IMAGE=photon-base:latest
FROM ${BASE_IMAGE} AS photon

FROM nvidia/cuda:12.8.1-base-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       ca-certificates \
       curl \
       libssl3 \
    && rm -rf /var/lib/apt/lists/*

# Install Miniconda
RUN curl -fsSL https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh \
    -o /tmp/miniconda.sh \
    && bash /tmp/miniconda.sh -b -p /opt/conda \
    && rm /tmp/miniconda.sh

ENV PATH=/opt/conda/bin:$PATH

# Create Python 3.13 environment
RUN conda install -y python=3.13 \
    && conda clean -afy

COPY --from=photon /usr/local/bin/kernel-manager /usr/local/bin/kernel-manager

EXPOSE 8090

ENTRYPOINT ["/usr/local/bin/kernel-manager"]
CMD []
