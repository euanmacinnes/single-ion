# photon-base-python3.13 — Photon kernel image with CPython 3.13
#
# Two-stage image: copies kernel-manager from photon-base into the official
# Python 3.13 slim image.  No CUDA — use conda/mamba variants for GPU workloads.
#
# Build from the monorepo root (photon-base must be built first):
#   docker build \
#     --build-arg BASE_IMAGE=photon-base:latest \
#     -f neutrino/files/base/Dockerfile.photon-base-python3.13 \
#     -t photon-base-python3.13:latest .

ARG BASE_IMAGE=photon-base:latest
FROM ${BASE_IMAGE} AS photon

FROM python:3.13-slim-bookworm

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       ca-certificates \
       libssl3 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=photon /usr/local/bin/kernel-manager /usr/local/bin/kernel-manager

EXPOSE 8090

ENTRYPOINT ["/usr/local/bin/kernel-manager"]
CMD []
